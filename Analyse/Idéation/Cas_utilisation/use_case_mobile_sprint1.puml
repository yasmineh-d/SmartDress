@startuml
skinparam actorStyle awesome
top to bottom direction

'========================
' STYLE GLOBAL
'========================
skinparam backgroundColor #F8F4EE
skinparam shadowing false
skinparam packageStyle rectangle
skinparam roundcorner 15

skinparam actor {
    BorderColor #604E34
    FontColor #2F2F2F
    BackgroundColor #F8F4EE
}

skinparam usecase {
    BackgroundColor #F8F4EE
    BorderColor #828B61
    FontColor #2F2F2F
    ArrowColor #828B61
}

skinparam rectangle {
    BorderColor #604E34
    FontColor #2F2F2F
    BackgroundColor #FFFFFF
}

'========================
' ACTEURS
'========================
actor "Utilisateur" as U
actor "Web (Laravel)" as WEB

'========================
' SYSTÈME
'========================
rectangle "Sprint 1 - Application Mobile (SmartDress)" {

    usecase "Consulter la page d'accueil" as UC1
    usecase "Consulter la garde-robe" as UC2
    usecase "Consulter les suggestions\nde tenues" as UC3
    usecase "Tableau de bord utilisateur" as UC4
    usecase "Gérer les favoris" as UC5
    usecase "Fournir l'API mobile" as UC6
}

'========================
' ASSOCIATIONS
'========================
U -- UC1
U -- UC2
U -- UC3
U -- UC4
U -- UC5

WEB -- UC6

@enduml
