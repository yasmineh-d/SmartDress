@startuml SmartDress_Sprint2
left to right direction
skinparam actorStyle awesome
skinparam package {
    BackgroundColor White
    BorderColor #5C4A35
}
skinparam usecase {
    BackgroundColor #F5EEE4
    BorderColor #889063
    ArrowColor #889063
}

actor "Utilisateur" as U
actor "Administrateur" as Admin

package "Sprint 2 – Fonctionnalités Avancées (SmartDress)" {

    ' ========================
    ' Améliorations Utilisateur
    ' ========================
    package "Améliorations Utilisateur" {
        usecase "Recevoir notifications\nde planification" as UC1
        usecase "Vérifier météo en temps réel" as UC2
        usecase "Analyser préférences\nautomatiquement" as UC3
        usecase "Partager une tenue" as UC4
        usecase "Ajouter un commentaire\nsur une tenue" as UC5
    }

    U -- UC1
    U -- UC2
    U -- UC3
    U -- UC4
    U -- UC5

    UC2 ..> UC3 : <<include>>

    ' ========================
    ' Améliorations Administrateur
    ' ========================
    package "Améliorations Administrateur" {
        usecase "Consulter tableau de bord avancé" as UC6
        usecase "Voir statistiques détaillées\n(vêtements, tenues, users)" as UC7
        usecase "Modérer les commentaires" as UC8
        usecase "Contrôler le contenu publié" as UC9
    }

    Admin -- UC6
    Admin -- UC7
    Admin -- UC8
    Admin -- UC9

    UC6 ..> UC7 : <<include>>
}

@enduml