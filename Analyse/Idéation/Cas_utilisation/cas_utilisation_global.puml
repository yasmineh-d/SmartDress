@startuml
top to bottom direction

actor Utilisateur
actor Administrateur

actor Utilisateur
actor Administrateur

rectangle "SmartDress — Use Case Diagram (Mobile + Web)" {

'=========================
' AUTHENTIFICATION
'=========================
usecase "S'inscrire" as UC1
usecase "Se connecter" as UC2
usecase "Se déconnecter" as UC3
usecase "Modifier profil" as UC4

Utilisateur -- UC1
Utilisateur -- UC2
Utilisateur -- UC3
Utilisateur -- UC4

Administrateur -- UC2
Administrateur -- UC3

'=========================
' GESTION VETEMENTS
'=========================
usecase "Gérer vêtements\n(Ajouter, Modifier,\nSupprimer, Consulter)" as UC5
usecase "Catégoriser vêtement" as UC6
usecase "Ajouter photo" as UC7

Utilisateur -- UC5

UC5 ..> UC6 : <<extend>>
UC5 ..> UC7 : <<extend>>

'=========================
' TENUES
'=========================
usecase "Planifier tenue" as UC8
usecase "Générer suggestion de tenue" as UC9
usecase "Enregistrer tenue favorite" as UC10

Utilisateur -- UC8
Utilisateur -- UC9

UC8 ..> UC9 : <<include>>

'=========================
' INTELLIGENCE SYSTEM
'=========================
usecase "Analyser favoris" as UC11
usecase "Vérifier météo" as UC12

UC9 ..> UC11 : <<include>>
UC9 ..> UC12 : <<include>>
UC9 ..> UC10 : <<extend>>

'=========================
' FAVORIS
'=========================
usecase "Gérer favoris" as UC13
Utilisateur -- UC13

'=========================
' ADMIN
'=========================
usecase "Gérer utilisateurs\n(Créer, Modifier,\nSupprimer, Consulter)" as UC14
usecase "Consulter statistiques" as UC15
usecase "Modérer contenu" as UC16

Administrateur -- UC14
Administrateur -- UC15
Administrateur -- UC16

}
@enduml